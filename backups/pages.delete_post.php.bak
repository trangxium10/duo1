<?php
session_start();
require_once __DIR__ . '/../includes/permissions.php';
// Only owner can delete posts
if (!is_owner()) {
    header('HTTP/1.1 403 Forbidden');
    echo 'Accès refusé.';
    exit;
}

$id = intval($_POST['id'] ?? 0);
$return = $_POST['return'] ?? 'posts.php';
if (!$id) {
    header('Location: ' . $return);
    exit;
}

$host = '127.0.0.1';
$db = 'do1';
$user = 'root';
$pass = 'xungkhium10';
$dsn = "mysql:host=$host;port=3306;dbname=$db;charset=utf8";
try {
    $pdo = new PDO($dsn, $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
} catch (Exception $e) {
    header('Location: ' . $return);
    exit;
}

// fetch post to find thumbnail
$stmt = $pdo->prepare('SELECT thumbnail FROM posts WHERE id = :id');
$stmt->execute([':id'=>$id]);
$post = $stmt->fetch(PDO::FETCH_ASSOC);
if ($post) {
    if (!empty($post['thumbnail'])) {
        $file = __DIR__ . '/../' . ltrim($post['thumbnail'], '/');
        if (file_exists($file)) @unlink($file);
    }
    $del = $pdo->prepare('DELETE FROM posts WHERE id = :id');
    $del->execute([':id'=>$id]);
}

header('Location: ' . $return);
exit;